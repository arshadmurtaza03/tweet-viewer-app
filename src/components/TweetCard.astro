---
import { formatNumber, formatDate, formatTweetText } from '../lib/format';
import MediaDownloadButton from './MediaDownloadButton.astro';

interface Props {
  tweet: {
    id: string;
    text: string;
    created_at: string;
    author: {
      name: string;
      screen_name: string;
      avatar_url?: string;
      profile_image_url?: string;
    };
    reposted_by?: {
      name: string;
      screen_name: string;
      avatar_url?: string;
    } | null;
    quote?: {
      id: string;
      text: string;
      created_at?: string;
      author: {
        name: string;
        screen_name: string;
        avatar_url?: string;
      };
      media?: {
        photos?: Array<{ url: string }>;
        videos?: Array<{ url: string; thumbnail_url?: string; hls_url?: string }>;
      };
    } | null;
    replies?: number;
    retweets?: number;
    likes?: number;
    views?: number;
    media?: {
      photos?: Array<{ url: string }>;
      videos?: Array<{ url: string; thumbnail_url?: string; hls_url?: string }>;
    };
  };
}

const { tweet } = Astro.props;
const avatar = tweet.author.avatar_url || tweet.author.profile_image_url || 'https://abs.twimg.com/sticky/default_profile_images/default_profile_normal.png';
const photos = tweet.media?.photos || [];
const videos = tweet.media?.videos || [];
const hasMedia = photos.length > 0 || videos.length > 0;
const formattedText = formatTweetText(tweet.text, hasMedia);
const formattedDate = formatDate(tweet.created_at);

const quote = tweet.quote;
const quotePhotos = quote?.media?.photos || [];
const quoteVideos = quote?.media?.videos || [];
---

<article class="group relative rounded-lg border border-hairline bg-canvas-soft-2/50 p-4 transition-all duration-200 hover:border-hairline-strong vercel-card-glow" data-tweet-id={tweet.id}>
  <!-- Reposted / Retweet Top Banner -->
  {tweet.reposted_by && (
    <div class="flex items-center space-x-1.5 text-xs text-mute font-mono mb-2 pb-2 border-b border-hairline/40">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-3.5 w-3.5 text-link shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M4.5 12c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3-3m-3 3l3 3m12-3l-3-3m3 3l-3 3" />
      </svg>
      <a href={`/${tweet.reposted_by.screen_name}`} class="font-medium text-ink hover:underline">
        {tweet.reposted_by.name}
      </a>
      <span>reposted</span>
    </div>
  )}

  <!-- Header: Avatar + User details + Timestamp -->
  <div class="flex items-start justify-between space-x-3 mb-3">
    <div class="flex items-center space-x-3 min-w-0">
      <a href={`/${tweet.author.screen_name}`} class="shrink-0 transition-opacity hover:opacity-80">
        <img
          src={avatar}
          alt={tweet.author.name}
          loading="lazy"
          referrerpolicy="no-referrer"
          class="h-10 w-10 rounded-full border border-hairline bg-canvas object-cover shadow-sm"
        />
      </a>
      <div class="min-w-0 flex-1">
        <a href={`/${tweet.author.screen_name}`} class="truncate font-sans text-sm font-semibold text-ink hover:underline block">
          {tweet.author.name}
        </a>
        <p class="truncate font-mono text-xs text-mute">@{tweet.author.screen_name}</p>
      </div>
    </div>
    
    <div class="flex items-center space-x-2 shrink-0">
      <time datetime={tweet.created_at} class="font-mono text-xs text-mute">{formattedDate}</time>
      <a 
        href={`/status/${tweet.id}`} 
        title="View single tweet thread & media" 
        class="rounded p-1 text-mute hover:bg-canvas hover:text-ink transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Tweet Text -->
  <div class="font-sans text-sm text-ink leading-relaxed mb-3 break-words" set:html={formattedText} />

  <!-- Embedded Photos Rendering (1, 2, 3, 4 Grid) -->
  {photos.length > 0 && (
    <div class="mb-4 rounded-lg overflow-hidden border border-hairline bg-canvas relative group/media">
      {photos.length === 1 && (
        <div class="relative overflow-hidden bg-black/40">
          <img 
            src={photos[0].url} 
            alt="Tweet image" 
            loading="lazy"
            referrerpolicy="no-referrer"
            class="tweet-lightbox-img tweet-media-img w-full h-auto max-h-[512px] object-cover cursor-zoom-in transition-transform duration-300 hover:scale-[1.02]"
            data-full-img={photos[0].url}
          />
          <div class="absolute bottom-2 right-2 opacity-0 group-hover/media:opacity-100 transition-opacity">
            <MediaDownloadButton mediaUrl={photos[0].url} mediaType="photo" filename={`tweet-${tweet.id}`} />
          </div>
        </div>
      )}

      {photos.length === 2 && (
        <div class="grid grid-cols-2 gap-0.5 bg-black/40">
          {photos.map((p, idx) => (
            <div class="relative overflow-hidden h-64">
              <img 
                src={p.url} 
                alt={`Tweet photo ${idx + 1}`} 
                loading="lazy"
                referrerpolicy="no-referrer"
                class="tweet-lightbox-img tweet-media-img h-full w-full object-cover cursor-zoom-in transition-transform duration-300 hover:scale-105"
                data-full-img={p.url}
              />
            </div>
          ))}
        </div>
      )}

      {photos.length === 3 && (
        <div class="grid grid-cols-3 gap-0.5 bg-black/40 h-72">
          <div class="col-span-2 relative overflow-hidden h-full">
            <img 
              src={photos[0].url} 
              alt="Tweet photo 1" 
              loading="lazy"
              referrerpolicy="no-referrer"
              class="tweet-lightbox-img tweet-media-img h-full w-full object-cover cursor-zoom-in transition-transform duration-300 hover:scale-105"
              data-full-img={photos[0].url}
            />
          </div>
          <div class="col-span-1 grid grid-rows-2 gap-0.5 h-full">
            {photos.slice(1).map((p, idx) => (
              <div class="relative overflow-hidden h-full">
                <img 
                  src={p.url} 
                  alt={`Tweet photo ${idx + 2}`} 
                  loading="lazy"
                  referrerpolicy="no-referrer"
                  class="tweet-lightbox-img tweet-media-img h-full w-full object-cover cursor-zoom-in transition-transform duration-300 hover:scale-105"
                  data-full-img={p.url}
                />
              </div>
            ))}
          </div>
        </div>
      )}

      {photos.length >= 4 && (
        <div class="grid grid-cols-2 gap-0.5 bg-black/40 h-72">
          {photos.slice(0, 4).map((p, idx) => (
            <div class="relative overflow-hidden h-full">
              <img 
                src={p.url} 
                alt={`Tweet photo ${idx + 1}`} 
                loading="lazy"
                referrerpolicy="no-referrer"
                class="tweet-lightbox-img tweet-media-img h-full w-full object-cover cursor-zoom-in transition-transform duration-300 hover:scale-105"
                data-full-img={p.url}
              />
            </div>
          ))}
        </div>
      )}
    </div>
  )}

  <!-- Embedded MP4 Videos / HLS Streams / GIFs Rendering -->
  {videos.length > 0 && (
    <div class="mb-4 rounded-lg overflow-hidden border border-hairline bg-black relative group/vid">
      {videos.map((vid) => {
        const proxyVideoUrl = `/api/video-proxy?url=${encodeURIComponent(vid.url)}`;
        return (
          <div class="relative">
            <video 
              controls 
              playsinline
              preload="metadata"
              poster={vid.thumbnail_url}
              referrerpolicy="no-referrer"
              class="tweet-video w-full max-h-[480px] object-contain bg-black"
              data-hls-src={vid.hls_url || undefined}
            >
              <source src={proxyVideoUrl} type="video/mp4" />
              <source src={vid.url} type="video/mp4" />
              Your browser does not support HTML5 MP4 video playback.
            </video>
            <div class="p-2 bg-canvas-soft-2 border-t border-hairline flex items-center justify-between">
              <span class="font-mono text-[11px] text-mute flex items-center space-x-1">
                <span class="h-2 w-2 rounded-full bg-cyan"></span>
                <span data-i18n="mp4_stream">Direct MP4 Video Stream</span>
              </span>
              <MediaDownloadButton mediaUrl={vid.url} mediaType="video" filename={`video-${tweet.id}`} />
            </div>
          </div>
        );
      })}
    </div>
  )}

  <!-- Embedded Quote Tweet Box -->
  {quote && (
    <div class="mb-4 rounded-lg border border-hairline bg-canvas p-3.5 space-y-2.5 transition-all hover:border-hairline-strong">
      <div class="flex items-center space-x-2">
        {quote.author.avatar_url && (
          <img 
            src={quote.author.avatar_url} 
            alt={quote.author.name} 
            loading="lazy" 
            referrerpolicy="no-referrer" 
            class="h-5 w-5 rounded-full object-cover border border-hairline"
          />
        )}
        <a href={`/${quote.author.screen_name}`} class="font-sans text-xs font-semibold text-ink hover:underline">
          {quote.author.name}
        </a>
        <span class="font-mono text-[11px] text-mute">@{quote.author.screen_name}</span>
      </div>
      
      <div class="font-sans text-xs text-ink leading-relaxed break-words" set:html={formatTweetText(quote.text)} />

      <!-- Quote Media Photos -->
      {quotePhotos.length > 0 && (
        <div class="rounded-md overflow-hidden border border-hairline bg-black/40 mt-2">
          <img 
            src={quotePhotos[0].url} 
            alt="Quoted media photo" 
            loading="lazy"
            referrerpolicy="no-referrer"
            class="tweet-lightbox-img tweet-media-img w-full max-h-64 object-cover cursor-zoom-in"
            data-full-img={quotePhotos[0].url}
          />
        </div>
      )}

      <!-- Quote Media Videos -->
      {quoteVideos.length > 0 && (
        <div class="rounded-md overflow-hidden border border-hairline bg-black mt-2">
          <video 
            controls 
            playsinline 
            preload="metadata" 
            poster={quoteVideos[0].thumbnail_url} 
            referrerpolicy="no-referrer" 
            class="w-full max-h-64 object-contain bg-black"
          >
            <source src={`/api/video-proxy?url=${encodeURIComponent(quoteVideos[0].url)}`} type="video/mp4" />
            <source src={quoteVideos[0].url} type="video/mp4" />
          </video>
        </div>
      )}
    </div>
  )}

  <!-- Footer Stats & Actions Bar -->
  <div class="flex items-center justify-between border-t border-hairline pt-3 text-xs text-mute font-mono">
    <!-- Engagement Metrics -->
    <div class="flex items-center space-x-4">
      {tweet.replies !== undefined && (
        <span class="flex items-center space-x-1" title="Replies">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 0 1-.923 1.785A5.969 5.969 0 0 0 6 21c1.282 0 2.47-.402 3.445-1.087.51-.358 1.156-.47 1.755-.383A9.704 9.704 0 0 0 12 20.25Z" />
          </svg>
          <span class="tabular-nums">{formatNumber(tweet.replies)}</span>
        </span>
      )}

      {tweet.retweets !== undefined && (
        <span class="flex items-center space-x-1" title="Retweets">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M4.5 12c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3-3m-3 3l3 3m12-3l-3-3m3 3l-3 3" />
          </svg>
          <span class="tabular-nums">{formatNumber(tweet.retweets)}</span>
        </span>
      )}

      {tweet.likes !== undefined && (
        <span class="flex items-center space-x-1" title="Likes">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
          <span class="tabular-nums">{formatNumber(tweet.likes)}</span>
        </span>
      )}
    </div>

    <!-- Action Link -->
    <a 
      href={`/status/${tweet.id}`}
      class="inline-flex items-center space-x-1 text-xs text-link hover:underline font-sans"
    >
      <span data-i18n="view_thread">View Thread &amp; Export</span>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3 w-3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</article>

<!-- Global Lightbox Modal + HLS Player + Error Fallback Initialization -->
<script>
  function setupMediaFallbacks() {
    const images = document.querySelectorAll('.tweet-media-img');
    images.forEach((img) => {
      if ((img as any).__fallbackBound) return;
      (img as any).__fallbackBound = true;
      img.addEventListener('error', () => {
        const parent = img.parentElement;
        if (parent) {
          parent.innerHTML = '<div class="flex items-center justify-center h-48 bg-[var(--theme-canvas-soft-2)] text-[var(--theme-mute)] text-xs font-mono gap-2"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"/></svg>Media unavailable</div>';
        }
      }, { once: true });
    });
  }

  function setupLightboxes() {
    const images = document.querySelectorAll('.tweet-lightbox-img');

    images.forEach((img) => {
      if ((img as any).__lightboxBound) return;
      (img as any).__lightboxBound = true;

      img.addEventListener('click', (e) => {
        e.preventDefault();
        const fullSrc = (img as HTMLImageElement).dataset.fullImg || (img as HTMLImageElement).src;

        const modal = document.createElement('div');
        modal.className = 'fixed inset-0 z-[100] flex items-center justify-center bg-black/90 backdrop-blur-md p-4 cursor-zoom-out';
        modal.style.animation = 'fadeIn 0.2s ease';
        modal.innerHTML = `
          <div class="relative max-w-5xl max-h-[90vh] overflow-hidden rounded-lg">
            <img src="${fullSrc}" referrerpolicy="no-referrer" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl" alt="Enlarged tweet image" />
            <button type="button" class="absolute top-2 right-2 rounded-full bg-black/70 p-2 text-white hover:bg-black transition-colors" title="Close (Esc)">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-5 w-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        `;

        const closeModal = () => {
          if (document.body.contains(modal)) {
            document.body.removeChild(modal);
          }
          document.removeEventListener('keydown', handleKey);
        };

        const handleKey = (ev: KeyboardEvent) => {
          if (ev.key === 'Escape') closeModal();
        };

        modal.onclick = closeModal;
        document.addEventListener('keydown', handleKey);
        document.body.appendChild(modal);
      });
    });
  }

  function setupHLSPlayers() {
    const videos = document.querySelectorAll<HTMLVideoElement>('video.tweet-video[data-hls-src]');
    if (videos.length === 0) return;

    videos.forEach((video) => {
      if ((video as any).__hlsBound) return;
      (video as any).__hlsBound = true;

      const hlsSrc = video.dataset.hlsSrc;
      if (!hlsSrc) return;

      if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = hlsSrc;
        return;
      }

      const loadHls = () => {
        if ((window as any).Hls) {
          initHls(video, hlsSrc);
          return;
        }
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/hls.js@1/dist/hls.min.js';
        script.onload = () => initHls(video, hlsSrc);
        script.onerror = () => {
          console.warn('HLS.js failed to load, falling back to MP4 proxy');
        };
        document.head.appendChild(script);
      };

      video.addEventListener('play', loadHls, { once: true });
    });
  }

  (window as any).__setupLightboxes = () => {
    setupLightboxes();
    setupMediaFallbacks();
    setupHLSPlayers();
  };

  setupMediaFallbacks();
  setupLightboxes();
  setupHLSPlayers();
  document.addEventListener('astro:page-load', () => {
    setupMediaFallbacks();
    setupLightboxes();
    setupHLSPlayers();
  });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
