---
import Layout from '../../layouts/Layout.astro';
import TweetCard from '../../components/TweetCard.astro';
import ThreadUnroller from '../../components/ThreadUnroller.astro';
import ExportButtons from '../../components/ExportButtons.astro';
import MediaDownloadButton from '../../components/MediaDownloadButton.astro';
import AdBanner from '../../components/AdBanner.astro';
import SearchInput from '../../components/SearchInput.astro';
import { fetchSyndicationTweet } from '../../lib/syndication';
import { fetchFixTweetStatus } from '../../lib/fxtwitter';
import { buildTweetSeo } from '../../lib/seo';
import type { FixTweetObject } from '../../lib/types';

export const prerender = false;

const { id } = Astro.params;

if (!id || !/^\d+$/.test(id)) {
  return Astro.redirect('/');
}

// 1. Dual-fetching strategy: Try Syndication first, fall back to FixTweet status API
let normalizedTweet: FixTweetObject | null = null;
let error: string | null = null;

// Try FixTweet status API directly for rich media & thread context
const fixRes = await fetchFixTweetStatus(id);
if (fixRes.tweet) {
  normalizedTweet = fixRes.tweet;
} else {
  // Fall back to X Syndication API
  const syndRes = await fetchSyndicationTweet(id);
  if (syndRes.tweet) {
    const t = syndRes.tweet;
    const photos = t.photos || [];
    const videos = t.video?.variants?.filter(v => v.content_type === 'video/mp4') || [];
    
    normalizedTweet = {
      id: t.id_str,
      text: t.text,
      created_at: t.created_at,
      author: {
        name: t.user.name,
        screen_name: t.user.screen_name,
        avatar_url: t.user.profile_image_url_https,
      },
      likes: t.favorite_count,
      replies: t.conversation_count || t.reply_count,
      retweets: t.retweet_count,
      media: {
        photos: photos.map(p => ({ type: 'photo' as const, url: p.media_url_https })),
        videos: videos.map(v => ({ type: 'video' as const, url: v.url })),
      },
      replying_to: t.in_reply_to_status_id_str ? {
        screen_name: t.in_reply_to_screen_name || '',
        post_id: t.in_reply_to_status_id_str
      } : null
    };
  } else {
    error = fixRes.error || syndRes.error || 'Tweet unavailable';
  }
}

// 2. Fetch Parent Thread up to max depth 3
const parentTweets: FixTweetObject[] = [];
if (normalizedTweet && normalizedTweet.replying_to?.post_id) {
  let currentParentId = normalizedTweet.replying_to.post_id;
  let depth = 0;
  
  while (currentParentId && depth < 2) {
    const parentRes = await fetchFixTweetStatus(currentParentId);
    if (parentRes.tweet) {
      parentTweets.unshift(parentRes.tweet);
      currentParentId = parentRes.tweet.replying_to?.post_id || '';
      depth++;
    } else {
      break;
    }
  }
}

// 3. Fetch Child Replies from author timeline
const childTweets: FixTweetObject[] = [];
if (normalizedTweet && normalizedTweet.author?.screen_name) {
  try {
    const userFeed = await fetchFixTweetProfile(normalizedTweet.author.screen_name);
    if (userFeed.tweets) {
      const replies = userFeed.tweets.filter(
        (t) => t.replying_to?.post_id === id && t.id !== id
      );
      childTweets.push(...replies);
    }
  } catch (e) {
    // optional child thread fetch fallback
  }
}

// Extract media URL for download button & SEO
const photos = normalizedTweet?.media?.photos || [];
const videos = normalizedTweet?.media?.videos || [];
const primaryMedia = videos.length > 0 ? videos[0].url : (photos.length > 0 ? photos[0].url : undefined);
const isVideo = videos.length > 0;

const seo = normalizedTweet
  ? buildTweetSeo(id, normalizedTweet.author.name, normalizedTweet.author.screen_name, normalizedTweet.text, primaryMedia)
  : null;

if (error || !normalizedTweet) {
  Astro.response.status = 404;
} else {
  Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');
}
---

<Layout
  title={seo?.title || `Tweet #${id} — My Tweet Viewer`}
  description={seo?.description || `View tweet ${id} anonymously.`}
  canonicalUrl={seo?.canonicalUrl}
  ogImage={seo?.ogImage}
>
  <div class="mx-auto max-w-4xl px-4 py-10">
    {error || !normalizedTweet ? (
      /* Tweet Error / Deleted state */
      <div class="rounded-lg border border-hairline bg-canvas-soft-2 p-8 text-center shadow-xl">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-canvas border border-hairline text-warning mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
        </div>
        <h1 class="font-sans text-xl font-semibold text-ink mb-2">Tweet Unavailable</h1>
        <p class="font-sans text-xs text-body mb-6">{error || 'This tweet does not exist, has been deleted, or is from a protected account.'}</p>

        <div class="pt-4 border-t border-hairline max-w-md mx-auto">
          <p class="font-mono text-xs text-mute mb-3">Search for another tweet or @username:</p>
          <SearchInput />
        </div>
      </div>
    ) : (
      <div class="space-y-8">
        <!-- Breadcrumbs Navigation -->
        <nav class="flex items-center space-x-2 font-mono text-xs text-mute">
          <a href="/" class="hover:text-ink transition-colors">Home</a>
          <span>/</span>
          <a href={`/${normalizedTweet.author.screen_name}`} class="hover:text-ink transition-colors">@{normalizedTweet.author.screen_name}</a>
          <span>/</span>
          <span class="text-ink font-medium">Status #{id}</span>
        </nav>

        <!-- Main Single Tweet Container -->
        <div class="rounded-lg border border-hairline bg-canvas-soft-2 p-6 vercel-card-glow space-y-6">
          <!-- Main Tweet Card -->
          <TweetCard tweet={normalizedTweet} />

          <!-- Media Download & Export Action Toolbar -->
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-t border-hairline pt-4">
            <!-- Left: Direct Media Download Button (if media available) -->
            <div>
              {primaryMedia ? (
                <MediaDownloadButton 
                  mediaUrl={primaryMedia} 
                  mediaType={isVideo ? 'video' : 'photo'} 
                  filename={`tweet-${id}`}
                />
              ) : (
                <span class="font-mono text-xs text-mute flex items-center space-x-1">
                  <span>&bull; No direct downloadable media attached</span>
                </span>
              )}
            </div>

            <!-- Right: Export Markdown & JSON -->
            <ExportButtons 
              tweet={{
                id_str: id,
                text: normalizedTweet.text,
                created_at: normalizedTweet.created_at,
                user: {
                  name: normalizedTweet.author.name,
                  screen_name: normalizedTweet.author.screen_name,
                },
                favorite_count: normalizedTweet.likes,
                retweet_count: normalizedTweet.retweets,
              }}
            />
          </div>

          <!-- Static Ad Banner Placeholder Next to / Below Download Toolbar -->
          <div class="pt-2">
            <AdBanner slotId="tweet-below-download" variant="inline" />
          </div>
        </div>

        <!-- Thread Unroller Section (Max depth: 3) -->
        <ThreadUnroller
          parentTweets={parentTweets}
          currentTweet={normalizedTweet}
          childTweets={childTweets}
          maxDepth={3}
        />
      </div>
    )}
  </div>
</Layout>
