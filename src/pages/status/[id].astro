---
import Layout from '../../layouts/Layout.astro';
import TweetCard from '../../components/TweetCard.astro';
import ThreadUnroller from '../../components/ThreadUnroller.astro';
import ExportButtons from '../../components/ExportButtons.astro';
import MediaDownloadButton from '../../components/MediaDownloadButton.astro';
import AdBanner from '../../components/AdBanner.astro';
import SearchInput from '../../components/SearchInput.astro';
import { fetchSyndicationTweet } from '../../lib/syndication';
import { fetchFixTweetStatus } from '../../lib/fxtwitter';
import { buildTweetSeo } from '../../lib/seo';
import { formatTweetText, formatDate, formatNumber } from '../../lib/format';

export const prerender = false;

const { id } = Astro.params;

if (!id || !/^\d+$/.test(id)) {
  return Astro.redirect('/');
}

// Fetch single tweet details from Syndication and FixTweet
const [syndResult, fixResult] = await Promise.all([
  fetchSyndicationTweet(id),
  fetchFixTweetStatus(id),
]);

const tweet = syndResult.tweet;
const fixTweet = fixResult.tweet;
const error = syndResult.error && fixResult.error ? 'Tweet unavailable' : null;

// Extract primary media for download & SEO
const photos = tweet?.photos || (fixTweet?.media?.photos ? fixTweet.media.photos.map(p => ({ media_url_https: p.url })) : []);
const videos = tweet?.video?.variants?.filter(v => v.content_type === 'video/mp4') || [];
const primaryMedia = videos.length > 0 ? videos[0].url : (photos.length > 0 ? photos[0].media_url_https : undefined);
const isVideo = videos.length > 0;

const seo = tweet
  ? buildTweetSeo(id, tweet.user.name, tweet.user.screen_name, tweet.text, primaryMedia)
  : null;

// Convert syndication format to TweetCard format if needed
const normalizedTweet = tweet ? {
  id: tweet.id_str,
  text: tweet.text,
  created_at: tweet.created_at,
  author: {
    name: tweet.user.name,
    screen_name: tweet.user.screen_name,
    avatar_url: tweet.user.profile_image_url_https,
  },
  likes: tweet.favorite_count,
  replies: tweet.conversation_count || tweet.reply_count,
  retweets: tweet.retweet_count,
  media: {
    photos: photos.map(p => ({ url: p.media_url_https })),
    videos: videos.map(v => ({ url: v.url })),
  },
} : (fixTweet ? {
  id: fixTweet.id,
  text: fixTweet.text,
  created_at: fixTweet.created_at,
  author: {
    name: fixTweet.author.name,
    screen_name: fixTweet.author.screen_name,
    avatar_url: fixTweet.author.avatar_url,
  },
  likes: fixTweet.likes,
  replies: fixTweet.replies,
  retweets: fixTweet.retweets,
  media: fixTweet.media,
} : null);
---

<Layout
  title={seo?.title || `Tweet #${id} — My Tweet Viewer`}
  description={seo?.description || `View tweet ${id} anonymously.`}
  canonicalUrl={seo?.canonicalUrl}
  ogImage={seo?.ogImage}
>
  <div class="mx-auto max-w-4xl px-4 py-10">
    {error || !normalizedTweet ? (
      /* Tweet Error / Deleted state */
      <div class="rounded-lg border border-hairline bg-canvas-soft-2 p-8 text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-canvas border border-hairline text-warning mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
        </div>
        <h1 class="font-sans text-xl font-semibold text-ink mb-2">Tweet Unavailable</h1>
        <p class="font-sans text-xs text-body mb-6">This tweet does not exist, has been deleted, or is from a protected account.</p>

        <div class="pt-4 border-t border-hairline">
          <SearchInput />
        </div>
      </div>
    ) : (
      <div class="space-y-8">
        <!-- Breadcrumbs Navigation -->
        <nav class="flex items-center space-x-2 font-mono text-xs text-mute">
          <a href="/" class="hover:text-ink transition-colors">Home</a>
          <span>/</span>
          <a href={`/${normalizedTweet.author.screen_name}`} class="hover:text-ink transition-colors">@{normalizedTweet.author.screen_name}</a>
          <span>/</span>
          <span class="text-ink">Status #{id}</span>
        </nav>

        <!-- Main Single Tweet View -->
        <div class="rounded-lg border border-hairline bg-canvas-soft-2 p-6 vercel-card-glow space-y-6">
          <!-- Main Tweet Card -->
          <TweetCard tweet={normalizedTweet} />

          <!-- Media Download & Export Action Toolbar -->
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-t border-hairline pt-4">
            <!-- Left: Direct Media Download Button (if media available) -->
            <div>
              {primaryMedia ? (
                <MediaDownloadButton 
                  mediaUrl={primaryMedia} 
                  mediaType={isVideo ? 'video' : 'photo'} 
                  filename={`tweet-${id}`}
                />
              ) : (
                <span class="font-mono text-xs text-mute">No direct media attached</span>
              )}
            </div>

            <!-- Right: Export Markdown & JSON -->
            <ExportButtons 
              tweet={{
                id_str: id,
                text: normalizedTweet.text,
                created_at: normalizedTweet.created_at,
                user: {
                  name: normalizedTweet.author.name,
                  screen_name: normalizedTweet.author.screen_name,
                },
                favorite_count: normalizedTweet.likes,
                retweet_count: normalizedTweet.retweets,
              }}
            />
          </div>

          <!-- Static Ad Banner Placeholder Next to / Below Download Toolbar -->
          <div class="pt-2">
            <AdBanner slotId="tweet-below-download" variant="inline" />
          </div>
        </div>

        <!-- Thread Unroller Section (Max depth: 3) -->
        <ThreadUnroller
          currentTweet={normalizedTweet}
          maxDepth={3}
        />
      </div>
    )}
  </div>
</Layout>
