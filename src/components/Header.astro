---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSelector from './LanguageSelector.astro';
---

<header class="sticky top-0 z-50 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md transition-all">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <!-- Brand Logo -->
    <a href="/" class="group flex items-center space-x-2.5 transition-opacity hover:opacity-90">
      <div class="flex h-8 w-8 items-center justify-center rounded-sm bg-ink text-on-primary transition-transform group-hover:scale-105 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
          <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.936 9.936 0 0024 4.59z"/>
        </svg>
      </div>
      <span class="font-sans text-sm sm:text-base font-semibold tracking-tight text-ink truncate">
        My Tweet Viewer<span class="text-link">.</span>
      </span>
    </a>

    <!-- Quick Search in Header (Desktop) -->
    <div class="hidden md:flex items-center">
      <form action="/" method="GET" class="relative w-64">
        <input
          type="text"
          name="q"
          data-i18n-placeholder="search_placeholder"
          placeholder="Search @username…"
          spellcheck="false"
          autocomplete="off"
          class="w-full h-8 rounded-sm border border-hairline bg-canvas-soft-2 px-3 pl-8 text-xs text-ink placeholder-mute transition-all focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-ink"
        />
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="absolute left-2.5 top-2 h-4 w-4 text-mute">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
      </form>
    </div>

    <!-- Navigation links, Theme Toggle, Language Selector & Mobile Search Toggle -->
    <nav class="flex items-center space-x-1.5 sm:space-x-2 text-xs">
      <!-- Mobile Search Button -->
      <button
        id="mobile-search-toggle"
        type="button"
        aria-label="Toggle mobile search"
        class="md:hidden rounded-md p-1.5 text-mute hover:bg-canvas-soft-2 hover:text-ink transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
      </button>

      <a href="/" class="px-2 py-1 font-medium text-body transition-colors hover:text-ink" data-i18n="nav_home">
        Home
      </a>
      <a href="/#favorites" class="px-2 py-1 font-medium text-body transition-colors hover:text-ink" data-i18n="nav_saved">
        Saved
      </a>

      <!-- Language Selector -->
      <LanguageSelector />

      <!-- Theme Selector Toggle -->
      <ThemeToggle />

      <span class="hidden sm:inline-flex items-center space-x-1.5 rounded-full border border-hairline bg-canvas-soft-2 px-2.5 py-1 text-[11px] font-mono text-mute">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        <span data-i18n="edge_active">Edge Active</span>
      </span>
    </nav>
  </div>

  <!-- Mobile Dropdown Search Input -->
  <div id="mobile-search-bar" class="hidden md:hidden border-t border-hairline bg-canvas-soft-2 px-4 py-3">
    <form action="/" method="GET" class="relative flex items-center space-x-2">
      <input
        type="text"
        name="q"
        data-i18n-placeholder="search_placeholder_long"
        placeholder="Search @username or paste tweet URL…"
        spellcheck="false"
        autocomplete="off"
        class="w-full h-9 rounded-md border border-hairline bg-canvas px-3 text-xs text-ink placeholder-mute focus:border-hairline-strong focus:outline-none"
      />
      <button type="submit" class="rounded-md bg-ink px-3 py-2 text-xs font-medium text-on-primary shrink-0" data-i18n="search_button">
        Search
      </button>
    </form>
  </div>
</header>

<script>
  function setupMobileSearch() {
    const btn = document.getElementById('mobile-search-toggle');
    const bar = document.getElementById('mobile-search-bar');
    if (btn && bar) {
      btn.onclick = () => {
        bar.classList.toggle('hidden');
      };
    }
  }
  setupMobileSearch();
  document.addEventListener('astro:page-load', setupMobileSearch);
</script>
