---
interface Props {
  tweet: {
    id_str: string;
    text: string;
    created_at: string;
    user: {
      name: string;
      screen_name: string;
    };
    favorite_count?: number;
    retweet_count?: number;
  };
}

const { tweet } = Astro.props;
const tweetJson = JSON.stringify(tweet);
---

<div class="flex flex-wrap items-center gap-2">
  <!-- Export Markdown -->
  <button
    id="export-md-btn"
    data-tweet={tweetJson}
    class="inline-flex items-center space-x-1.5 rounded-md border border-hairline bg-canvas-soft-2 px-3 py-1.5 text-xs font-mono text-ink transition-colors hover:border-hairline-strong active:scale-95"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5 text-cyan">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
    </svg>
    <span>Export .MD</span>
  </button>

  <!-- Export JSON -->
  <button
    id="export-json-btn"
    data-tweet={tweetJson}
    class="inline-flex items-center space-x-1.5 rounded-md border border-hairline bg-canvas-soft-2 px-3 py-1.5 text-xs font-mono text-ink transition-colors hover:border-hairline-strong active:scale-95"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5 text-pink-500">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
    </svg>
    <span>Export JSON</span>
  </button>

  <!-- Copy Link -->
  <button
    id="copy-link-btn"
    class="inline-flex items-center space-x-1.5 rounded-md border border-hairline bg-canvas-soft-2 px-3 py-1.5 text-xs font-mono text-mute transition-colors hover:border-hairline-strong hover:text-ink active:scale-95"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
    </svg>
    <span id="copy-text">Copy Link</span>
  </button>
</div>

<script>
  function setupExportButtons() {
    const mdBtn = document.getElementById('export-md-btn');
    const jsonBtn = document.getElementById('export-json-btn');
    const copyBtn = document.getElementById('copy-link-btn');

    function downloadFile(content: string, filename: string, type: string) {
      const blob = new Blob([content], { type });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }

    if (mdBtn) {
      mdBtn.addEventListener('click', () => {
        try {
          const tweet = JSON.parse(mdBtn.dataset.tweet || '{}');
          const md = `# Tweet by ${tweet.user?.name} (@${tweet.user?.screen_name})

${tweet.text}

---
- **Author:** ${tweet.user?.name} (@${tweet.user?.screen_name})
- **Date:** ${tweet.created_at}
- **Tweet ID:** ${tweet.id_str}
- **Likes:** ${tweet.favorite_count || 0}
- **Retweets:** ${tweet.retweet_count || 0}

*Exported via My Tweet Viewer (mytweetviewer.com)*
`;
          downloadFile(md, `tweet-${tweet.id_str}.md`, 'text/markdown;charset=utf-8');
        } catch (e) {
          console.error(e);
        }
      });
    }

    if (jsonBtn) {
      jsonBtn.addEventListener('click', () => {
        try {
          const tweet = JSON.parse(jsonBtn.dataset.tweet || '{}');
          downloadFile(JSON.stringify(tweet, null, 2), `tweet-${tweet.id_str}.json`, 'application/json');
        } catch (e) {
          console.error(e);
        }
      });
    }

    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const textEl = document.getElementById('copy-text');
          if (textEl) {
            textEl.textContent = 'Copied!';
            setTimeout(() => {
              textEl.textContent = 'Copy Link';
            }, 2000);
          }
        });
      });
    }
  }

  setupExportButtons();
  document.addEventListener('astro:page-load', setupExportButtons);
</script>
