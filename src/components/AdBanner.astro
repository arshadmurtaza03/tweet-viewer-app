---
interface Props {
  slotId?: string;
  variant?: 'banner' | 'sidebar' | 'inline';
  className?: string;
}

const { slotId = 'default', variant = 'banner', className = '' } = Astro.props;

const variantClasses = {
  banner: 'w-full min-h-[90px]',
  sidebar: 'w-full min-h-[250px]',
  inline: 'w-full min-h-[100px]',
};
---

<aside 
  aria-label="Advertisement" 
  class={`relative overflow-hidden rounded-md border border-hairline bg-canvas-soft-2/60 p-4 transition-colors hover:border-hairline-strong ${variantClasses[variant]} ${className}`}
>
  <div class="flex h-full w-full flex-col items-center justify-center space-y-1 text-center">
    <div class="flex items-center space-x-2">
      <span class="rounded bg-canvas px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-mute border border-hairline">
        ADVERTISEMENT
      </span>
    </div>
    <p class="font-mono text-xs text-mute/80">
      Sponsored Content Slot #{slotId}
    </p>
  </div>
  
  <!-- Subtle decorative corner accent -->
  <div class="absolute right-0 top-0 h-6 w-6 translate-x-3 -translate-y-3 rotate-45 bg-hairline/30 pointer-events-none"></div>
</aside>
