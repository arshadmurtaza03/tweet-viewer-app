---
import { formatNumber, formatDate, formatTweetText } from '../lib/format';

interface Props {
  tweet: {
    id: string;
    text: string;
    created_at: string;
    author: {
      name: string;
      screen_name: string;
      avatar_url?: string;
      profile_image_url?: string;
    };
    replies?: number;
    retweets?: number;
    likes?: number;
    views?: number;
    media?: {
      photos?: Array<{ url: string }>;
      videos?: Array<{ url: string; thumbnail_url?: string }>;
    };
  };
}

const { tweet } = Astro.props;
const avatar = tweet.author.avatar_url || tweet.author.profile_image_url || 'https://abs.twimg.com/sticky/default_profile_images/default_profile_normal.png';
const formattedText = formatTweetText(tweet.text);
const formattedDate = formatDate(tweet.created_at);
const photos = tweet.media?.photos || [];
const videos = tweet.media?.videos || [];
---

<article class="group relative rounded-lg border border-hairline bg-canvas-soft-2/50 p-4 transition-all duration-200 hover:border-hairline-strong vercel-card-glow">
  <!-- Header: Avatar + User details + Timestamp -->
  <div class="flex items-start justify-between space-x-3 mb-3">
    <div class="flex items-center space-x-3 min-w-0">
      <a href={`/${tweet.author.screen_name}`} class="shrink-0 transition-opacity hover:opacity-80">
        <img
          src={avatar}
          alt={tweet.author.name}
          loading="lazy"
          class="h-10 w-10 rounded-full border border-hairline bg-canvas object-cover"
        />
      </a>
      <div class="min-w-0 flex-1">
        <a href={`/${tweet.author.screen_name}`} class="truncate font-sans text-sm font-semibold text-ink hover:underline block">
          {tweet.author.name}
        </a>
        <p class="truncate font-mono text-xs text-mute">@{tweet.author.screen_name}</p>
      </div>
    </div>
    
    <div class="flex items-center space-x-2 shrink-0">
      <time datetime={tweet.created_at} class="font-mono text-xs text-mute">{formattedDate}</time>
      <a 
        href={`/status/${tweet.id}`} 
        title="View single tweet thread" 
        class="rounded p-1 text-mute hover:bg-canvas hover:text-ink transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Tweet Body Text -->
  <div class="font-sans text-sm text-ink leading-relaxed mb-3 break-words" set:html={formattedText} />

  <!-- Media Grid -->
  {photos.length > 0 && (
    <div class={`grid gap-2 mb-4 rounded-md overflow-hidden border border-hairline ${photos.length > 1 ? 'grid-cols-2' : 'grid-cols-1'}`}>
      {photos.map((photo, i) => (
        <a href={photo.url} target="_blank" rel="noopener noreferrer" class="relative group/img overflow-hidden block bg-canvas">
          <img 
            src={photo.url} 
            alt={`Tweet media ${i + 1}`} 
            loading="lazy"
            class="w-full h-auto max-h-[400px] object-cover transition-transform duration-300 group-hover/img:scale-105"
          />
        </a>
      ))}
    </div>
  )}

  {videos.length > 0 && (
    <div class="mb-4 rounded-md overflow-hidden border border-hairline bg-canvas">
      {videos.map((vid) => (
        <video 
          controls 
          preload="metadata"
          poster={vid.thumbnail_url}
          class="w-full max-h-[450px] object-contain bg-black"
        >
          <source src={vid.url} type="video/mp4" />
          Your browser does not support video playback.
        </video>
      ))}
    </div>
  )}

  <!-- Footer Stats & Actions -->
  <div class="flex items-center justify-between border-t border-hairline pt-3 text-xs text-mute font-mono">
    <!-- Engagement Stats -->
    <div class="flex items-center space-x-4">
      {tweet.replies !== undefined && (
        <span class="flex items-center space-x-1" title="Replies">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 0 1-.923 1.785A5.969 5.969 0 0 0 6 21c1.282 0 2.47-.402 3.445-1.087.51-.358 1.156-.47 1.755-.383A9.704 9.704 0 0 0 12 20.25Z" />
          </svg>
          <span class="tabular-nums">{formatNumber(tweet.replies)}</span>
        </span>
      )}

      {tweet.retweets !== undefined && (
        <span class="flex items-center space-x-1" title="Retweets">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M4.5 12c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3-3m-3 3l3 3m12-3l-3-3m3 3l-3 3" />
          </svg>
          <span class="tabular-nums">{formatNumber(tweet.retweets)}</span>
        </span>
      )}

      {tweet.likes !== undefined && (
        <span class="flex items-center space-x-1" title="Likes">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
          <span class="tabular-nums">{formatNumber(tweet.likes)}</span>
        </span>
      )}
    </div>

    <!-- Action Link -->
    <a 
      href={`/status/${tweet.id}`}
      class="inline-flex items-center space-x-1 text-xs text-link hover:underline font-sans"
    >
      <span>View Thread</span>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3 w-3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</article>
