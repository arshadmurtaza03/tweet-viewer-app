---
import Layout from '../layouts/Layout.astro';
import ProfileHeader from '../components/ProfileHeader.astro';
import TweetCard from '../components/TweetCard.astro';
import AdBanner from '../components/AdBanner.astro';
import SearchInput from '../components/SearchInput.astro';
import { fetchFixTweetProfile } from '../lib/fxtwitter';
import { buildProfileSeo } from '../lib/seo';

export const prerender = false;

const { username } = Astro.params;

// Validate username parameter
if (!username || !/^[a-zA-Z0-9_]{1,15}$/.test(username)) {
  return Astro.redirect('/');
}

const { user, tweets, bottom_cursor, error } = await fetchFixTweetProfile(username);
const seo = user ? buildProfileSeo(user.screen_name, user.name, user.description, user.avatar_url) : null;

if (error || !user) {
  Astro.response.status = 404;
} else {
  Astro.response.headers.set('Cache-Control', 'public, max-age=1800, stale-while-revalidate=300');
}

const ssrHasMedia = tweets?.some(t => (t.media?.photos && t.media.photos.length > 0) || (t.media?.videos && t.media.videos.length > 0)) || false;
const initialTweetsCount = tweets?.length || 0;
---

<Layout
  title={seo?.title || `@${username} — My Tweet Viewer`}
  description={seo?.description || `View @${username}'s tweets anonymously.`}
  canonicalUrl={seo?.canonicalUrl}
  ogImage={seo?.ogImage}
>
  {error || !user ? (
    /* Error / Profile Not Found State */
    <div class="mx-auto max-w-2xl px-4 py-20 text-center">
      <div class="rounded-lg border border-hairline bg-canvas-soft-2 p-8 shadow-sm">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-canvas border border-hairline text-warning mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
        </div>
        <h1 class="font-sans text-xl font-semibold text-ink mb-2" data-i18n="profile_unavailable">Profile Unavailable</h1>
        <p class="font-sans text-xs text-body mb-6">{error || `User @${username} could not be found or account is restricted.`}</p>

        <div class="pt-2 border-t border-hairline">
          <p class="font-mono text-xs text-mute mb-4" data-i18n="try_search">Try searching for another user or link:</p>
          <SearchInput />
        </div>
      </div>
    </div>
  ) : (
    /* Active Profile Layout */
    <div>
      <!-- Profile Header Component -->
      <ProfileHeader user={user} />

      <!-- Timeline Main Grid -->
      <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
          <!-- Tweets Column (2-cols width on desktop) -->
          <div class="lg:col-span-2 space-y-6">
            <div class="flex items-center justify-between border-b border-hairline pb-3">
              <h2 class="font-mono text-xs uppercase tracking-wider text-mute" data-i18n="profile_feed">Profile Feed &amp; Tweets</h2>
              <span class="font-mono text-xs text-emerald-400 font-medium">&bull; <span data-i18n="edge_active">Edge Active</span></span>
            </div>

            <!-- Main Tweets Container -->
            <div id="tweets-container" class="space-y-4" data-ssr-has-media={ssrHasMedia ? 'true' : 'false'}>
              {tweets && tweets.length > 0 && tweets.map((tweet) => (
                <TweetCard tweet={tweet} />
              ))}
            </div>

            <!-- Loading Spinner Placeholder for Client Sourcing -->
            <div id="client-loading-spinner" class={`py-12 text-center ${initialTweetsCount > 0 && ssrHasMedia ? 'hidden' : ''}`}>
              <div class="inline-flex items-center space-x-3 rounded-full border border-hairline bg-canvas-soft-2 px-5 py-2.5 shadow-sm">
                <svg class="h-4 w-4 animate-spin text-link" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="font-mono text-xs text-ink font-medium">Sourcing timeline &amp; media for @{username}…</span>
              </div>
            </div>

            <!-- Empty Feed Fallback Container -->
            <div id="empty-feed-fallback" class="hidden rounded-lg border border-hairline bg-canvas-soft-2/50 p-6 space-y-4">
              <div class="flex items-center space-x-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-full bg-canvas border border-hairline text-link">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-sans text-sm font-semibold text-ink">View any Tweet by @{user.screen_name}</h3>
                  <p class="font-sans text-xs text-mute">Paste a tweet link or status ID to unroll the thread and download media.</p>
                </div>
              </div>

              <form action="/" method="GET" class="relative">
                <div class="flex items-center space-x-2">
                  <input
                    type="text"
                    name="q"
                    placeholder={`e.g. https://x.com/${user.screen_name}/status/...`}
                    class="w-full rounded-md border border-hairline bg-canvas px-3 py-2 text-xs text-ink placeholder-mute focus:border-hairline-strong focus:outline-none"
                  />
                  <button type="submit" class="rounded-md bg-ink px-4 py-2 text-xs font-medium text-on-primary hover:opacity-90 shrink-0" data-i18n="view_tweet">
                    View Tweet
                  </button>
                </div>
              </form>
            </div>

            <!-- Load More Tweets Button Bar -->
            <div id="load-more-container" class="flex flex-col items-center space-y-3 pt-4 pb-2">
              <button
                id="load-more-btn"
                type="button"
                data-username={username}
                data-cursor={bottom_cursor || ''}
                class="group inline-flex items-center space-x-2 rounded-lg border border-hairline bg-canvas-soft-2 px-8 py-3.5 text-sm font-medium text-ink transition-all hover:border-hairline-strong hover:bg-canvas hover:shadow-md active:scale-[0.98]"
              >
                <svg id="load-more-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 transition-transform group-hover:translate-y-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
                </svg>
                <span id="load-more-text" data-i18n="load_more">Load More Tweets</span>
              </button>
              <span id="throttle-badge" class="hidden text-xs font-mono text-warning bg-warning/10 border border-warning/20 rounded-full px-3 py-1"></span>
            </div>
          </div>

          <!-- Sidebar Column (1-col width on desktop) -->
          <div class="space-y-6">
            <!-- Static Ad Banner Placeholder in Profile Sidebar -->
            <AdBanner slotId="profile-sidebar" variant="sidebar" />

            <!-- Profile Privacy & Fast Facts Box -->
            <div class="rounded-lg border border-hairline bg-canvas-soft-2 p-5 text-xs space-y-3">
              <h3 class="font-mono uppercase text-mute tracking-wider" data-i18n="privacy_title">Privacy &amp; Edge Cache</h3>
              <p class="text-body leading-relaxed" data-i18n="privacy_desc">
                Profile metadata is fetched directly from public endpoints. Zero tracking cookies or credentials required.
              </p>
              <div class="pt-2 border-t border-hairline space-y-1 font-mono text-mute">
                <div class="flex justify-between">
                  <span data-i18n="cache_ttl">Cache TTL:</span>
                  <span class="text-ink" data-i18n="minutes_30">30 minutes</span>
                </div>
                <div class="flex justify-between">
                  <span data-i18n="privacy_level">Privacy:</span>
                  <span class="text-emerald-400" data-i18n="privacy_anon">100% Anonymous</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  )}

  {seo?.jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(seo.jsonLd)} />
  )}
</Layout>

<script>
  function initProfileTimeline() {
    const container = document.getElementById('tweets-container');
    const spinner = document.getElementById('client-loading-spinner');
    const fallback = document.getElementById('empty-feed-fallback');
    const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement | null;
    const loadMoreText = document.getElementById('load-more-text');
    const throttleBadge = document.getElementById('throttle-badge');

    if (!container || !loadMoreBtn) return;

    const username = loadMoreBtn.dataset.username || '';
    let currentCursor = loadMoreBtn.dataset.cursor || '';
    let isLoading = false;
    let lastFetchTime = 0;
    const THROTTLE_MS = 2000;

    // Track all rendered tweet IDs to eliminate duplicate page 1 repeats
    const seenTweetIds = new Set<string>();
    const existingCards = container.querySelectorAll('[data-tweet-id]');
    existingCards.forEach((c) => {
      const tid = c.getAttribute('data-tweet-id');
      if (tid) seenTweetIds.add(tid);
    });

    function formatNumber(num?: number): string {
      if (!num) return '0';
      if (num >= 1000000) return (num / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
      if (num >= 1000) return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
      return num.toLocaleString();
    }

    function formatDate(ds?: string): string {
      if (!ds) return '';
      try {
        const d = new Date(ds);
        if (isNaN(d.getTime())) return ds;
        const now = new Date();
        const diff = Math.floor((now.getTime() - d.getTime()) / 1000);
        if (diff < 60) return diff + 's';
        if (diff < 3600) return Math.floor(diff / 60) + 'm';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h';
        if (diff < 604800) return Math.floor(diff / 86400) + 'd';
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: d.getFullYear() !== now.getFullYear() ? 'numeric' : undefined });
      } catch { return ds; }
    }

    function escapeHtml(str: string): string {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function formatTweetText(text?: string): string {
      if (!text) return '';
      let s = escapeHtml(text);
      s = s.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" rel="noopener noreferrer" class="text-link hover:underline">$1</a>');
      s = s.replace(/(^|[^a-zA-Z0-9_])@([a-zA-Z0-9_]{1,15})/g, '$1<a href="/$2" class="text-link hover:underline font-medium">@$2</a>');
      s = s.replace(/(^|[^a-zA-Z0-9_])#([a-zA-Z0-9_]+)/g, '$1<a href="https://x.com/hashtag/$2" target="_blank" rel="noopener noreferrer" class="text-link hover:underline">#$2</a>');
      return s.replace(/\n/g, '<br/>');
    }

    function buildTweetCardHtml(t: any): string {
      const avatar = t.author?.avatar_url || t.author?.profile_image_url || 'https://abs.twimg.com/sticky/default_profile_images/default_profile_normal.png';
      const name = escapeHtml(t.author?.name || username);
      const handle = escapeHtml(t.author?.screen_name || username);
      const date = formatDate(t.created_at);
      const textHtml = formatTweetText(t.text || '');
      const photos = t.media?.photos || [];
      const videos = t.media?.videos || [];

      let repostBannerHtml = '';
      if (t.reposted_by) {
        const rName = escapeHtml(t.reposted_by.name || username);
        const rHandle = escapeHtml(t.reposted_by.screen_name || username);
        repostBannerHtml = `<div class="flex items-center space-x-1.5 text-xs text-mute font-mono mb-2 pb-2 border-b border-hairline/40">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-3.5 w-3.5 text-link shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M4.5 12c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3-3m-3 3l3 3m12-3l-3-3m3 3l-3 3"/></svg>
          <a href="/${rHandle}" class="font-medium text-ink hover:underline">${rName}</a>
          <span>reposted</span>
        </div>`;
      }

      let quoteCardHtml = '';
      if (t.quote) {
        const q = t.quote;
        const qAvatar = q.author?.avatar_url || 'https://abs.twimg.com/sticky/default_profile_images/default_profile_normal.png';
        const qName = escapeHtml(q.author?.name || '');
        const qHandle = escapeHtml(q.author?.screen_name || '');
        const qText = formatTweetText(q.text || '');
        const qPhotos = q.media?.photos || [];
        const qVideos = q.media?.videos || [];

        let qMediaHtml = '';
        if (qPhotos.length > 0) {
          qMediaHtml = `<div class="rounded-md overflow-hidden border border-hairline bg-black/40 mt-2">
            <img src="${qPhotos[0].url}" alt="Quoted image" loading="lazy" referrerpolicy="no-referrer" class="tweet-lightbox-img tweet-media-img w-full max-h-64 object-cover cursor-zoom-in" data-full-img="${qPhotos[0].url}"/>
          </div>`;
        } else if (qVideos.length > 0) {
          const proxyVid = `/api/video-proxy?url=${encodeURIComponent(qVideos[0].url)}`;
          qMediaHtml = `<div class="rounded-md overflow-hidden border border-hairline bg-black mt-2">
            <video controls playsinline preload="metadata" poster="${qVideos[0].thumbnail_url || ''}" referrerpolicy="no-referrer" class="w-full max-h-64 object-contain bg-black">
              <source src="${proxyVid}" type="video/mp4"/>
              <source src="${qVideos[0].url}" type="video/mp4"/>
            </video>
          </div>`;
        }

        quoteCardHtml = `<div class="mb-4 rounded-lg border border-hairline bg-canvas p-3.5 space-y-2.5 transition-all hover:border-hairline-strong">
          <div class="flex items-center space-x-2">
            <img src="${qAvatar}" alt="${qName}" loading="lazy" referrerpolicy="no-referrer" class="h-5 w-5 rounded-full object-cover border border-hairline"/>
            <a href="/${qHandle}" class="font-sans text-xs font-semibold text-ink hover:underline">${qName}</a>
            <span class="font-mono text-[11px] text-mute">@${qHandle}</span>
          </div>
          <div class="font-sans text-xs text-ink leading-relaxed break-words">${qText}</div>
          ${qMediaHtml}
        </div>`;
      }

      let mediaHtml = '';

      // Photo Grids
      if (photos.length === 1) {
        mediaHtml = `<div class="mb-4 rounded-lg overflow-hidden border border-hairline bg-canvas relative group/media">
          <div class="relative overflow-hidden bg-black/40">
            <img src="${photos[0].url}" alt="Tweet image" loading="lazy" referrerpolicy="no-referrer" class="tweet-lightbox-img tweet-media-img w-full h-auto max-h-[512px] object-cover cursor-zoom-in transition-transform duration-300 hover:scale-[1.02]" data-full-img="${photos[0].url}"/>
            <div class="absolute bottom-2 right-2 opacity-0 group-hover/media:opacity-100 transition-opacity">
              <a href="${photos[0].url}" target="_blank" download class="inline-flex items-center space-x-1 rounded bg-black/80 px-2.5 py-1 text-[11px] font-mono text-white backdrop-blur-md hover:bg-black">
                <span>Download</span>
              </a>
            </div>
          </div>
        </div>`;
      } else if (photos.length === 2) {
        mediaHtml = `<div class="mb-4 rounded-lg overflow-hidden border border-hairline bg-canvas relative group/media">
          <div class="grid grid-cols-2 gap-0.5 bg-black/40">
            ${photos.map((p: any, idx: number) => `<div class="relative overflow-hidden h-64"><img src="${p.url}" alt="Photo ${idx+1}" loading="lazy" referrerpolicy="no-referrer" class="tweet-lightbox-img tweet-media-img h-full w-full object-cover cursor-zoom-in transition-transform duration-300 hover:scale-105" data-full-img="${p.url}"/></div>`).join('')}
          </div>
        </div>`;
      } else if (photos.length === 3) {
        mediaHtml = `<div class="mb-4 rounded-lg overflow-hidden border border-hairline bg-canvas relative group/media">
          <div class="grid grid-cols-3 gap-0.5 bg-black/40 h-72">
            <div class="col-span-2 relative overflow-hidden h-full"><img src="${photos[0].url}" alt="Photo 1" loading="lazy" referrerpolicy="no-referrer" class="tweet-lightbox-img tweet-media-img h-full w-full object-cover cursor-zoom-in transition-transform duration-300 hover:scale-105" data-full-img="${photos[0].url}"/></div>
            <div class="col-span-1 grid grid-rows-2 gap-0.5 h-full">
              ${photos.slice(1).map((p: any, idx: number) => `<div class="relative overflow-hidden h-full"><img src="${p.url}" alt="Photo ${idx+2}" loading="lazy" referrerpolicy="no-referrer" class="tweet-lightbox-img tweet-media-img h-full w-full object-cover cursor-zoom-in transition-transform duration-300 hover:scale-105" data-full-img="${p.url}"/></div>`).join('')}
            </div>
          </div>
        </div>`;
      } else if (photos.length >= 4) {
        mediaHtml = `<div class="mb-4 rounded-lg overflow-hidden border border-hairline bg-canvas relative group/media">
          <div class="grid grid-cols-2 gap-0.5 bg-black/40 h-72">
            ${photos.slice(0, 4).map((p: any, idx: number) => `<div class="relative overflow-hidden h-full"><img src="${p.url}" alt="Photo ${idx+1}" loading="lazy" referrerpolicy="no-referrer" class="tweet-lightbox-img tweet-media-img h-full w-full object-cover cursor-zoom-in transition-transform duration-300 hover:scale-105" data-full-img="${p.url}"/></div>`).join('')}
          </div>
        </div>`;
      }

      // Videos (routed through /api/video-proxy?url=... with referrerpolicy="no-referrer")
      if (videos.length > 0) {
        mediaHtml += videos.map((v: any) => {
          const proxyUrl = `/api/video-proxy?url=${encodeURIComponent(v.url)}`;
          return `<div class="mb-4 rounded-lg overflow-hidden border border-hairline bg-black relative group/vid">
            <div class="relative">
              <video controls playsinline preload="metadata" poster="${v.thumbnail_url || ''}" referrerpolicy="no-referrer" class="tweet-video w-full max-h-[480px] object-contain bg-black" ${v.hls_url ? `data-hls-src="${v.hls_url}"` : ''}>
                <source src="${proxyUrl}" type="video/mp4"/>
                <source src="${v.url}" type="video/mp4"/>
                Your browser does not support MP4 video playback.
              </video>
              <div class="p-2 bg-canvas-soft-2 border-t border-hairline flex items-center justify-between">
                <span class="font-mono text-[11px] text-mute flex items-center space-x-1"><span class="h-2 w-2 rounded-full bg-cyan"></span><span>Direct MP4 Video Stream</span></span>
                <a href="${v.url}" target="_blank" download class="inline-flex items-center space-x-1 rounded bg-black/80 px-2.5 py-1 text-[11px] font-mono text-white hover:bg-black"><span>Download MP4</span></a>
              </div>
            </div>
          </div>`;
        }).join('');
      }

      return `<article class="group relative rounded-lg border border-hairline bg-canvas-soft-2/50 p-4 transition-all duration-200 hover:border-hairline-strong vercel-card-glow" data-tweet-id="${t.id}">
        ${repostBannerHtml}
        <div class="flex items-start justify-between space-x-3 mb-3">
          <div class="flex items-center space-x-3 min-w-0">
            <a href="/${handle}" class="shrink-0 transition-opacity hover:opacity-80">
              <img src="${avatar}" alt="${name}" loading="lazy" referrerpolicy="no-referrer" class="h-10 w-10 rounded-full border border-hairline bg-canvas object-cover shadow-sm"/>
            </a>
            <div class="min-w-0 flex-1">
              <a href="/${handle}" class="truncate font-sans text-sm font-semibold text-ink hover:underline block">${name}</a>
              <p class="truncate font-mono text-xs text-mute">@${handle}</p>
            </div>
          </div>
          <div class="flex items-center space-x-2 shrink-0">
            <time datetime="${t.created_at}" class="font-mono text-xs text-mute">${date}</time>
            <a href="/status/${t.id}" title="View single tweet thread &amp; media" class="rounded p-1 text-mute hover:bg-canvas hover:text-ink transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
            </a>
          </div>
        </div>
        <div class="font-sans text-sm text-ink leading-relaxed mb-3 break-words">${textHtml}</div>
        ${quoteCardHtml}
        ${mediaHtml}
        <div class="flex items-center justify-between border-t border-hairline pt-3 text-xs text-mute font-mono">
          <div class="flex items-center space-x-4">
            ${t.replies !== undefined ? `<span class="flex items-center space-x-1" title="Replies"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 0 1-.923 1.785A5.969 5.969 0 0 0 6 21c1.282 0 2.47-.402 3.445-1.087.51-.358 1.156-.47 1.755-.383A9.704 9.704 0 0 0 12 20.25Z"/></svg><span class="tabular-nums">${formatNumber(t.replies)}</span></span>` : ''}
            ${t.retweets !== undefined ? `<span class="flex items-center space-x-1" title="Retweets"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M4.5 12c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3-3m-3 3l3 3m12-3l-3-3m3 3l-3 3"/></svg><span class="tabular-nums">${formatNumber(t.retweets)}</span></span>` : ''}
            ${t.likes !== undefined ? `<span class="flex items-center space-x-1" title="Likes"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg><span class="tabular-nums">${formatNumber(t.likes)}</span></span>` : ''}
          </div>
          <a href="/status/${t.id}" class="inline-flex items-center space-x-1 text-xs text-link hover:underline font-sans">
            <span>View Thread &amp; Export</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3 w-3"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </article>`;
    }

    async function fetchTimelineFromGateway(cursor?: string): Promise<{ tweets: any[]; bottom_cursor?: string }> {
      let endpointUrl = `/api/syndication?username=${encodeURIComponent(username)}`;
      if (cursor) {
        endpointUrl += `&cursor=${encodeURIComponent(cursor)}`;
      }

      const res = await fetch(endpointUrl);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      return { tweets: data.tweets || [], bottom_cursor: data.bottom_cursor };
    }

    const ssrHasMedia = container.dataset.ssrHasMedia === 'true';
    const initialCount = container.children.length;

    // Sourcing timeline & media on initial load
    if (initialCount === 0 || !ssrHasMedia) {
      if (spinner) spinner.classList.remove('hidden');
      
      fetchTimelineFromGateway()
        .then(({ tweets, bottom_cursor }) => {
          if (spinner) spinner.classList.add('hidden');
          if (tweets.length > 0) {
            container.innerHTML = '';
            seenTweetIds.clear();
            for (const t of tweets) {
              if (seenTweetIds.has(t.id)) continue;
              seenTweetIds.add(t.id);
              container.insertAdjacentHTML('beforeend', buildTweetCardHtml(t));
            }
            if (bottom_cursor) {
              currentCursor = bottom_cursor;
              loadMoreBtn.dataset.cursor = bottom_cursor;
            }
            if (typeof (window as any).__setupLightboxes === 'function') {
              (window as any).__setupLightboxes();
            }
          } else {
            if (initialCount === 0 && fallback) fallback.classList.remove('hidden');
          }
        })
        .catch((err) => {
          console.warn('Timeline gateway sourcing error:', err);
          if (spinner) spinner.classList.add('hidden');
          if (initialCount === 0 && fallback) fallback.classList.remove('hidden');
        });
    }

    // Load More click handler (with deduplication & max_id calculation)
    loadMoreBtn.addEventListener('click', async () => {
      if (isLoading) return;

      const now = Date.now();
      const elapsed = now - lastFetchTime;
      if (elapsed < THROTTLE_MS) {
        loadMoreBtn.disabled = true;
        loadMoreBtn.classList.add('opacity-50', 'cursor-not-allowed');
        const left = Math.ceil((THROTTLE_MS - elapsed) / 1000);
        if (throttleBadge) {
          throttleBadge.textContent = `Please wait ${left}s`;
          throttleBadge.classList.remove('hidden');
        }
        setTimeout(() => {
          if (throttleBadge) throttleBadge.classList.add('hidden');
          loadMoreBtn.disabled = false;
          loadMoreBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }, THROTTLE_MS - elapsed);
        return;
      }

      isLoading = true;
      loadMoreBtn.disabled = true;
      loadMoreBtn.classList.add('opacity-50');
      if (loadMoreText) loadMoreText.textContent = 'Loading…';

      try {
        const { tweets: fetchedTweets, bottom_cursor: newCursor } = await fetchTimelineFromGateway(currentCursor);
        lastFetchTime = Date.now();

        // Filter out any tweets that are ALREADY in seenTweetIds
        const freshTweets = fetchedTweets.filter((t) => !seenTweetIds.has(t.id));

        if (freshTweets.length === 0) {
          if (loadMoreText) loadMoreText.textContent = 'No more tweets to load';
          loadMoreBtn.disabled = true;
          loadMoreBtn.classList.add('opacity-50', 'cursor-not-allowed');
          return;
        }

        for (const t of freshTweets) {
          seenTweetIds.add(t.id);
          container.insertAdjacentHTML('beforeend', buildTweetCardHtml(t));
        }

        if (newCursor) {
          currentCursor = newCursor;
          loadMoreBtn.dataset.cursor = newCursor;
          if (loadMoreText) loadMoreText.textContent = 'Load More Tweets';
          loadMoreBtn.disabled = false;
          loadMoreBtn.classList.remove('opacity-50');
        } else {
          // If no cursor was returned, derive max_id cursor from the oldest tweet
          const oldestId = freshTweets[freshTweets.length - 1].id;
          try {
            currentCursor = (BigInt(oldestId) - 1n).toString();
            loadMoreBtn.dataset.cursor = currentCursor;
            if (loadMoreText) loadMoreText.textContent = 'Load More Tweets';
            loadMoreBtn.disabled = false;
            loadMoreBtn.classList.remove('opacity-50');
          } catch {
            if (loadMoreText) loadMoreText.textContent = 'No more tweets to load';
            loadMoreBtn.disabled = true;
            loadMoreBtn.classList.add('opacity-50', 'cursor-not-allowed');
          }
        }

        if (typeof (window as any).__setupLightboxes === 'function') {
          (window as any).__setupLightboxes();
        }
      } catch (err) {
        console.error('Load more error:', err);
        if (loadMoreText) loadMoreText.textContent = 'Failed to load — Retry';
        loadMoreBtn.disabled = false;
        loadMoreBtn.classList.remove('opacity-50');
      } finally {
        isLoading = false;
      }
    });
  }

  initProfileTimeline();
  document.addEventListener('astro:page-load', initProfileTimeline);
</script>
