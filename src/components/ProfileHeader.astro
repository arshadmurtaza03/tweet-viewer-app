---
import { formatNumber } from '../lib/format';
import type { FixTweetUser } from '../lib/types';

interface Props {
  user: FixTweetUser;
}

const { user } = Astro.props;
const avatar = user.avatar_url || user.profile_image_url || 'https://abs.twimg.com/sticky/default_profile_images/default_profile_normal.png';
const banner = user.banner_url || user.profile_banner_url;
---

<div class="relative w-full border-b border-hairline bg-canvas-soft">
  <!-- Banner Container -->
  <div class="h-44 sm:h-52 w-full bg-gradient-to-r from-cyan-900/30 via-violet-900/20 to-canvas-soft relative overflow-hidden">
    {banner ? (
      <img src={banner} alt={`${user.name} banner`} class="h-full w-full object-cover" />
    ) : (
      <div class="absolute inset-0 vercel-mesh-bg opacity-40"></div>
    )}
  </div>

  <!-- Profile Content Container -->
  <div class="mx-auto max-w-4xl px-4 pb-6">
    <div class="flex items-end justify-between -mt-16 sm:-mt-20 mb-4">
      <!-- Avatar -->
      <div class="relative h-24 w-24 sm:h-32 sm:w-32 overflow-hidden rounded-full border-4 border-canvas bg-canvas shadow-xl">
        <img src={avatar} alt={user.name} class="h-full w-full object-cover" />
      </div>

      <!-- Action Buttons (Favorite toggle) -->
      <div class="flex items-center space-x-2">
        <button
          id="toggle-fav-btn"
          data-username={user.screen_name}
          data-name={user.name}
          data-avatar={avatar}
          class="inline-flex items-center space-x-2 rounded-full border border-hairline bg-canvas-soft-2 px-4 py-2 text-xs font-medium text-ink transition-all hover:border-hairline-strong active:scale-95"
        >
          <svg id="fav-icon-empty" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 text-pink-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
          <svg id="fav-icon-filled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 text-pink-500 hidden">
            <path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001Z" />
          </svg>
          <span id="fav-label">Favorite</span>
        </button>

        <a
          href={`https://x.com/${user.screen_name}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center space-x-1.5 rounded-full border border-hairline bg-canvas px-3 py-2 text-xs font-medium text-mute hover:text-ink transition-colors"
        >
          <span>Official X</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </div>

    <!-- User Information -->
    <div class="space-y-3">
      <div>
        <h1 class="font-sans text-2xl sm:text-3xl font-semibold tracking-tight text-ink flex items-center space-x-2">
          <span>{user.name}</span>
          {user.protected && (
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-warning">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          )}
        </h1>
        <p class="font-mono text-sm text-mute">@{user.screen_name}</p>
      </div>

      {user.description && (
        <p class="font-sans text-sm text-body leading-relaxed max-w-3xl whitespace-pre-line">
          {user.description}
        </p>
      )}

      <!-- Metadata & Stats -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs font-mono text-mute pt-1">
        {user.location && (
          <span class="flex items-center space-x-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span>{user.location}</span>
          </span>
        )}

        {user.followers_count !== undefined && (
          <span class="flex items-center space-x-1">
            <strong class="font-sans text-sm font-semibold text-ink tabular-nums">{formatNumber(user.followers_count)}</strong>
            <span>Followers</span>
          </span>
        )}

        {(user.following_count !== undefined || user.friends_count !== undefined) && (
          <span class="flex items-center space-x-1">
            <strong class="font-sans text-sm font-semibold text-ink tabular-nums">{formatNumber(user.following_count || user.friends_count)}</strong>
            <span>Following</span>
          </span>
        )}
      </div>
    </div>
  </div>
</div>

<script>
  function setupFavoriteToggle() {
    const btn = document.getElementById('toggle-fav-btn');
    const emptyIcon = document.getElementById('fav-icon-empty');
    const filledIcon = document.getElementById('fav-icon-filled');
    const label = document.getElementById('fav-label');

    if (!btn) return;

    const username = btn.dataset.username || '';
    const name = btn.dataset.name || '';
    const avatar = btn.dataset.avatar || '';

    function isFav(): boolean {
      try {
        const favs = JSON.parse(localStorage.getItem('mtv_favorites') || '[]');
        return favs.some((f: any) => f.username === username);
      } catch (e) {
        return false;
      }
    }

    function updateUI(active: boolean) {
      if (active) {
        emptyIcon?.classList.add('hidden');
        filledIcon?.classList.remove('hidden');
        if (label) label.textContent = 'Saved';
        btn?.classList.add('border-pink-500/50', 'bg-pink-500/10');
      } else {
        emptyIcon?.classList.remove('hidden');
        filledIcon?.classList.add('hidden');
        if (label) label.textContent = 'Favorite';
        btn?.classList.remove('border-pink-500/50', 'bg-pink-500/10');
      }
    }

    updateUI(isFav());

    btn.addEventListener('click', () => {
      try {
        const favs = JSON.parse(localStorage.getItem('mtv_favorites') || '[]');
        const exists = favs.some((f: any) => f.username === username);

        let updated;
        if (exists) {
          updated = favs.filter((f: any) => f.username !== username);
        } else {
          updated = [{ username, name, avatar }, ...favs];
        }

        localStorage.setItem('mtv_favorites', JSON.stringify(updated));
        window.dispatchEvent(new Event('favorites-updated'));
        updateUI(!exists);
      } catch (e) {
        console.error(e);
      }
    });
  }

  setupFavoriteToggle();
  document.addEventListener('astro:page-load', setupFavoriteToggle);
</script>
